# Firebase Web App Configuration Example
# Copy this file to .env and fill in your actual values

# Get these from Firebase Console > Project Settings > General > Your Apps (Web)
REACT_APP_FIREBASE_API_KEY=AIzaSyDxxx_xxxxx_xxxxxx_xxxxx
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-123.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-123
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-123.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Optional: For local development with emulators
# REACT_APP_USE_EMULATOR=false

# Hosting
REACT_APP_HOSTING_URL=https://your-project-123.web.app
