rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    function onlyVolunteerEditableFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'phoneNumber', 'address', 'updatedAt']);
    }

    function validVolunteerCreate(volunteerId) {
      return signedIn()
        && request.auth.uid == volunteerId
        && request.resource.data.keys().hasOnly([
          'name',
          'email',
          'phoneNumber',
          'address',
          'availableHours',
          'joinedDate',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.email == request.auth.token.email;
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    match /volunteers/{volunteerId} {
      allow read, write: if isAdmin();
      allow create: if validVolunteerCreate(volunteerId);
      allow read: if signedIn() && request.auth.uid == volunteerId;
      allow update: if signedIn()
        && request.auth.uid == volunteerId
        && onlyVolunteerEditableFields();
      allow delete: if false;
    }

    match /serviceEvents/{eventId} {
      allow read, write: if isAdmin();
      allow read: if signedIn()
        && request.auth.uid in resource.data.assignedVolunteers;
      allow create, update, delete: if false;
    }

    match /reminderRules/{ruleId} {
      allow read, write: if isAdmin();
    }

    match /reminders/{reminderId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /sentMessages/{messageId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
